# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Prisma / Supabase (Postgres)
# https://www.prisma.io/docs/reference/database-reference/connection-urls#env
# DATABASE_URL uses the pooled connection (pgbouncer, port 6543) for app queries.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL bypasses the pooler (port 5432) and is required for migrations/db push.
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# Next Auth
# You can generate a new secret on the command line with:
# openssl rand -base64 32
# https://next-auth.js.org/configuration/options#secret
# NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

NEXT_PUBLIC_PROJECT_URL="http://localhost:3000"

# Next Auth Google Provider
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Fetch repo statistics
GITHUB_TOKEN=""

# Email allowed to author/edit blog posts (must match the email on your sign-in account)
ADMIN_EMAIL=""

# Supabase Storage, used server-side only to upload blog images.
# SUPABASE_URL is the project URL (Project Settings > API): https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY is the secret service_role key (Project Settings > API) — never expose it to the client.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
